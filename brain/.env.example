# ============================================================
# Hermes Assistant Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- GPU Node (Main PC) --- REQUIRED ---
# Local IP address of your main PC running Ollama
GPU_NODE_HOST=192.168.0.145
GPU_NODE_PORT=11434

# AI model to use (must be pulled on the main PC first)
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_TIMEOUT=120
INFERENCE_RETRY_ATTEMPTS=2

# --- Z.ai / Zhipu AI (Cloud Inference) ---
# When ZAI_API_KEY is set, Z.ai replaces Ollama as inference backend
# Models: glm-4-flash-250414 (free), glm-5.2 (1M context), glm-4.7, glm-5
# Get API key at: https://open.bigmodel.cn/
ZAI_API_KEY=
ZAI_BASE_URL=https://api.z.ai/api/paas/v4/
ZAI_MODEL=glm-4-flash-250414
ZAI_TIMEOUT=120

# --- Assistant ---
ASSISTANT_NAME=Hermes
MAX_HISTORY=20

# Custom system prompt (optional — leave blank for default)
# SYSTEM_PROMPT=You are Hermes, a helpful home assistant.

# --- HTTP API Server (used when no Telegram token is set) ---
API_HOST=0.0.0.0
API_PORT=8080
# Uncomment and set a strong secret to require auth on the API
# API_SECRET=change-me-to-a-strong-random-string

# --- Telegram Bot (optional) ---
# Leave blank to use HTTP API mode instead
TELEGRAM_TOKEN=
# Comma-separated Telegram user IDs allowed to chat (leave blank = allow all)
# Find your ID by messaging @userinfobot on Telegram
TELEGRAM_ALLOWED_USERS=

# --- Tool Calling ---
# Permite que el LLM decida qué herramientas usar (requiere modelo compatible)
TOOL_CALLING_ENABLED=true
# Máximo de iteraciones de herramientas por mensaje
TOOL_MAX_ITERATIONS=5

# --- Multi-Agent ---
# Permite delegar tareas a agentes especializados (researcher, coder, analyst, media_specialist)
AGENTS_ENABLED=true

# --- Web Browsing ---
WEB_ENABLED=true
WEB_SEARCH_REGION=es-ar
WEB_SEARCH_MAX_RESULTS=5
WEB_USE_BROWSER=false

# --- TTS / Voice ---
# Backend por defecto: "edge" (100% gratis) o "voxtral" (premium + clonación de voz)
TTS_BACKEND=edge
# API key de Mistral AI para Voxtral TTS (obtener en console.mistral.ai)
# Necesaria solo si usás Voxtral o clonación de voz
# Precio: $0.016 / 1000 caracteres
MISTRAL_API_KEY=

# --- Google Stitch (Diseño Web con IA) ---
# API key de Google Stitch para generar UI/HTML con IA
# Obtener en stitch.withgoogle.com → Settings → API Key
# 350 generaciones/mes gratis
STITCH_API_KEY=

# --- Social Media Publishing ---
# YouTube Data API v3 (para subir videos directo)
# Crear proyecto en console.cloud.google.com → APIs → YouTube Data API v3
# Crear credenciales OAuth 2.0 (tipo Desktop)
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
# Refresh token (se obtiene la primera vez con el flujo OAuth, Hermes te guía)
YOUTUBE_REFRESH_TOKEN=
# Make.com webhook URL para publicar en Instagram, TikTok, X, Facebook
# Crear escenario en Make → Custom Webhook → copiar la URL
MAKE_WEBHOOK_URL=

# --- Media Analysis ---
# Directorio donde se descargan videos
MEDIA_DOWNLOAD_DIR=data/media
# Duración máxima de video permitida (segundos)
MEDIA_MAX_DURATION=600
# Modelo Whisper para transcripción (tiny, base, small, medium, large-v3)
WHISPER_MODEL_SIZE=base
# Dispositivo para Whisper (cpu o cuda)
WHISPER_DEVICE=cpu
# Modelo de visión para análisis de frames (debe estar en Ollama)
VISION_MODEL=llava
# Cantidad de frames a analizar por video
VISION_FRAMES=4

# --- Obsidian Vault ---
# Ruta a tu vault de Obsidian (sincronizado via Syncthing)
# En Windows: C:\Users\chsan\hermes-vault
# En Linux (Lenovo): /home/hermes/hermes-vault (o donde Syncthing sincronice)
VAULT_PATH=
# Habilitar búsqueda semántica en notas (necesita sentence-transformers y chromadb)
RAG_ENABLED=true

# --- Email (IMAP/SMTP) ---
# Para Gmail: usar "contraseña de aplicación" (no la contraseña normal)
# Ir a myaccount.google.com → Seguridad → Contraseñas de aplicaciones
EMAIL_ADDRESS=
EMAIL_PASSWORD=
IMAP_SERVER=imap.gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# --- Google Calendar ---
# Descargar credentials.json de console.cloud.google.com y ponerlo en brain/data/google_credentials.json
# El token se genera automáticamente la primera vez

# --- Stock Footage (para videos virales) ---
# Pexels: gratis en pexels.com/api → "Your API Key"
PEXELS_API_KEY=
# Pixabay: gratis en pixabay.com/api/docs/ → "Key"
PIXABAY_API_KEY=

# --- System Commands ---
# Lista de comandos del sistema permitidos (separados por coma)
ALLOWED_COMMANDS=df,free,uptime,docker ps,systemctl status,ls,cat,head,tail,wc,date,whoami,hostname,ip addr
